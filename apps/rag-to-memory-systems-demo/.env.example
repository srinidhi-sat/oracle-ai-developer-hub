ORACLE_DB_USERNAME=memory_demo
ORACLE_DB_PASSWORD=memory_demo
ORACLE_DB_DSN=localhost:1521/FREEPDB1

DEMO_TENANT_ID=acme-support
# DEMO_USER_ID is the raw identifier (e.g. an email or external ID).
DEMO_USER_ID=jane_doe@example.com
DEMO_AGENT_ID=agent:support_v1

# Optional. If set, the demo uses OpenAI for the model and extraction layers.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Optional. Set to any truthy value to force SimulatedModel + RuleBasedExtractor
# even when OPENAI_API_KEY is set. Useful for offline testing or capping cost
# without removing the key from .env. The CLI also accepts --simulated for the
# same effect on a single run.
# FORCE_SIMULATED=1

# Optional. Floor for fact/episode relevance tiers in the assembled prompt.
# This is a demo-only convenience; the article doesn't describe it.
# - low      accept everything (default; matches the article's behavior)
# - standard drop [low] hits; keeps [standard] and [high]
# - high     keep only [high] hits — very strict, useful on small corpora
# Policies, preferences, and recent trace events are never filtered.
# CLI override: --min-relevance {low,standard,high}
# MEMORY_MIN_RELEVANCE=standard
