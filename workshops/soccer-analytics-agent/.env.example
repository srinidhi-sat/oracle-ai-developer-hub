# OCI Generative AI (bearer-token auth, no OCI SDK)
#
# On workshop day the INSTRUCTOR provides these THREE values — paste them in below:
#   1. OCI_GENAI_ENDPOINT   (e.g. https://inference.generativeai.<region>.oci.oraclecloud.com)
#   2. OCI_COMPARTMENT_ID   (an ocid1.compartment.oc1..... string)
#   3. OCI_GENAI_API_KEY    (an sk-... bearer key)
# OCI_GENAI_MODEL_ID is preset to the workshop model — leave it as-is.
# Do NOT commit real values; .env is gitignored, this .env.example is the template.
OCI_GENAI_ENDPOINT=REPLACE_ME_WORKSHOP_DAY_ENDPOINT
OCI_GENAI_API_KEY=sk-REPLACE_ME_WORKSHOP_DAY
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..REPLACE_ME_WORKSHOP_DAY
OCI_GENAI_MODEL_ID=xai.grok-4

# Oracle AI Database Free container (dedicated soccer-oracle on port 1525).
# These passwords are dev-only defaults — the workshop's docker-compose
# bakes ADMIN_PASSWORD into the container at first boot. Do NOT reuse
# these credentials for any networked/shared deployment.
ORACLE_DSN=localhost:1525/FREEPDB1
ORACLE_USER=soccer
ORACLE_PASSWORD=SoccerAgent2026#
ORACLE_ADMIN_PASSWORD=SoccerAdmin2026#

# In-DB ONNX embedding model name (loaded by setup skill)
ORACLE_EMBED_MODEL=ALL_MINILM_L6_V2

# LangChain OracleDB vector-store showcase (optional overrides)
ORACLE_LANGCHAIN_VECTOR_TABLE=SOCCER_LANGCHAIN_DOCS
ORACLE_LANGCHAIN_VECTOR_INDEX=IDX_SOCCER_LC_HNSW
ORACLE_LANGCHAIN_TEXT_INDEX=IDX_SOCCER_LC_TEXT
ORACLE_LANGCHAIN_HYBRID_INDEX=IDX_SOCCER_LC_HYBRID
